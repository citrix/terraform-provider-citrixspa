# Terraform variables for SPA resource discovery
# Copy this file to terraform.tfvars and fill in your actual credentials

# Required for all authentication methods
customer_id = "your-customer-id-here"
base_url    = "https://api.cloud.com/accessSecurity"

# Authentication Method 1: Direct token authentication
# Use this if you have a pre-generated bearer token
# auth_token = "your-auth-token-here"

# Authentication Method 2: Service Principal authentication (recommended)
# Use these instead of auth_token for OAuth2 flow
# Uncomment and fill in these values to use service principal authentication
client_id     = "your-client-id-here"
client_secret = "your-client-secret-here"

# Note: Use only ONE authentication method at a time
# Comment out auth_token if using service principal authentication

# Example values:
# customer_id = "abc123def456"
# auth_token  = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
# client_id   = "12345678-1234-1234-1234-123456789012"
# client_secret = "your-client-secret-value"
# base_url    = "https://api.cloud.com"
